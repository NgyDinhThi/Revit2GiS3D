<Window x:Class="RevitToGISsupport.UI.MainWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="420" Width="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Export Revit → JSON / GLB"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,16">
            <TextBlock Text="Chọn View để xem Online" FontWeight="Bold"/>
            <ComboBox x:Name="cbView"
                      Width="420"
                      DisplayMemberPath="Name"
                      Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical">
            <Button x:Name="btnCollect"
                    Content="Collect"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="btnCollect_Click"/>
            <Button x:Name="btnExportGLB"
                    Content="Export GLB"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="btnExportGLB_Click"/>
            <Button x:Name="btnOnlineWatch"
                    Content="Xem file online"
                    Height="40"
                    Click="btnOnlineWatch_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   x:Name="lblStatus"
                   Text="Status: ..."
                   Margin="0,16,0,0"/>
    </Grid>
</Window>

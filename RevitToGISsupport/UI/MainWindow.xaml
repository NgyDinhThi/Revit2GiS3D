<Window x:Class="RevitToGISsupport.UI.MainWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RevitToGISsupport.UI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Chọn phương thức Export"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="Black"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button x:Name="btnExportGLB"
            Content=" Xuất file .GLB"
            Width="200" Height="40"
            Margin="0,0,0,10"
            Background="#4CAF50"
            Foreground="White"
            FontWeight="Bold"
            Click="btnExportGLB_Click"/>

            
        </StackPanel>

    </Grid>
</Window>

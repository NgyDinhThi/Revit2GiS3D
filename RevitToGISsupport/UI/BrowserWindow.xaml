<Window x:Class="RevitToGISsupport.UI.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Project Browser (Clone)" Height="680" Width="520"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="8">
            <TextBox x:Name="tbSearch"
                     Width="260" Height="26"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     TextChanged="tbSearch_TextChanged"
                     ToolTip="Search (lọc theo tên leaf)"/>
            <Button x:Name="btnRefresh"
                    Width="90" Height="26"
                    Margin="0,0,8,0"
                    Content="Refresh"
                    Click="btnRefresh_Click"/>
            <Button x:Name="btnPublish"
                    Width="120" Height="26"
                    Content="Publish to Web"
                    Click="btnPublish_Click"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Server:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="tbServer"
                     Grid.Column="1"
                     Height="26"
                     VerticalContentAlignment="Center"
                     Text="http://127.0.0.1:5000"/>

            <TextBlock Grid.Column="2" Text="ProjectId:" VerticalAlignment="Center" Margin="10,0,6,0"/>
            <TextBox x:Name="tbProjectId"
                     Grid.Column="3"
                     Height="26"
                     VerticalContentAlignment="Center"
                     Text="P001"/>
        </Grid>

        <TreeView x:Name="tvRoot"
                  Grid.Row="2"
                  Margin="8"
                  MouseDoubleClick="Tree_MouseDoubleClick">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Title}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <TextBlock x:Name="lblStatus"
                   Grid.Row="3"
                   Margin="8"
                   Text="Ready."
                   TextWrapping="Wrap"/>
    </Grid>
</Window>

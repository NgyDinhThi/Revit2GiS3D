<Window x:Class="RevitToGISsupport.UI.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RevitToGISsupport.UI"
        mc:Ignorable="d"
        Title="BrowserWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="8" Grid.Row="0">
            <TextBox x:Name="tbSearch" Width="240" Height="26" Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     TextChanged="tbSearch_TextChanged"
                     ToolTip="Search (lọc theo tên leaf)"/>
            <Button x:Name="btnRefresh" Width="90" Height="26" Content="Refresh"
                    Click="btnRefresh_Click"/>
        </DockPanel>

        <TabControl Grid.Row="1" Margin="8">
            <TabItem Header="Views">
                <TreeView x:Name="tvViews" MouseDoubleClick="Tree_MouseDoubleClick">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>

            <TabItem Header="Sheets">
                <TreeView x:Name="tvSheets" MouseDoubleClick="Tree_MouseDoubleClick">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>

            <TabItem Header="Schedules">
                <TreeView x:Name="tvSchedules" MouseDoubleClick="Tree_MouseDoubleClick">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Title}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
